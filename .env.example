# PostgreSQL container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=crm

# App database config inside Docker Compose network
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=crm
DB_SSLMODE=disable

# Redis inside Docker Compose network
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT / tokens
JWT_ACCESS_SECRET=local-access-secret-change-me
JWT_REFRESH_SECRET=local-refresh-secret-change-me

ACCESS_TTL=15m
REFRESH_TTL=720h

# HTTP
HTTP_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
FRONTEND_PORT=3000
VITE_API_URL=/api
FRONTEND_DEV_PORT=5173
VITE_DEV_API_URL=/api
VITE_USE_POLLING=true
