# Docker Compose
COMPOSE_PROJECT_NAME=crm-dev

# PostgreSQL container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=crm
POSTGRES_PORT=5432

# App database config inside Docker
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/crm?schema=public
# Optional: needed for `prisma migrate diff --from-migrations ...` checks.
# Create this database manually in local Postgres before using it.
# SHADOW_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crm_shadow?schema=public
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=crm

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PORT=6379

# JWT / tokens
JWT_ACCESS_SECRET=local-access-secret-change-me
JWT_REFRESH_SECRET=local-refresh-secret-change-me

ACCESS_TTL=15m
REFRESH_TTL=720h

# Seeded login user
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-strong-password
SEED_ADMIN_ROLE=admin
SEED_ADMIN_OVERWRITE=false

# HTTP
HTTP_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
FRONTEND_PORT=3000
VITE_API_URL=/api
FRONTEND_DEV_PORT=5173
VITE_DEV_API_URL=/api
VITE_USE_POLLING=true
